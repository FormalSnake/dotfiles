--- a/src/shell/control_center/tabs/bluetooth_tab.cpp
+++ b/src/shell/control_center/tabs/bluetooth_tab.cpp
@@ -582,7 +582,13 @@
     key.push_back(':');
     key += std::to_string(static_cast<int>(d.batteryPercent));
     key.push_back(':');
-    key += std::to_string(static_cast<int>(d.rssi));
+    // RSSI is only shown for Available devices, and only as a coarse percent.
