diff --git a/src/shell/control_center/tabs/bluetooth_tab.cpp b/src/shell/control_center/tabs/bluetooth_tab.cpp
--- a/src/shell/control_center/tabs/bluetooth_tab.cpp
+++ b/src/shell/control_center/tabs/bluetooth_tab.cpp
@@ -672,8 +672,14 @@ void BluetoothTab::rebuildDeviceList(Renderer& renderer) {
               if (m_service == nullptr) {
                 return;
               }
-              m_service->stopDiscovery();
-              m_service->startDiscovery();
+              // Discovery consumes power and reveals nearby devices. Make it an
+              // explicit toggle rather than leaving a manual scan running until
+              // the Bluetooth tab is closed.
+              if (m_service->state().discovering) {
+                m_service->stopDiscovery();
+              } else {
+                m_service->startDiscovery();
+              }
             },
         })
     );
