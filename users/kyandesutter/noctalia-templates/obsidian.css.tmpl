/*
 * Noctalia -> Obsidian (Minimal). Wallpaper-derived dynamic palette, generated by
 * Noctalia into ~/Notes/.obsidian/snippets/noctalia.css and hot-reloaded by
 * Obsidian on write (no reload hook needed). Enabled via appearance.json's
 * enabledCssSnippets (seeded by scripts/obsidian-vault-bootstrap.sh on Linux).
 *
 * Layered over kepano's Minimal theme: it overrides both Minimal's own swatches
 * (--bg/ui/tx/ax) and Obsidian's core color roles, all !important so it wins over
 * whichever Minimal color scheme is active underneath (its scheme blocks are the
 * two-class .theme-dark.minimal-flexoki-dark form, un-!important). `.default`
 * tokens track the active light/dark mode; Noctalia re-renders on every flip, in
 * lockstep with Obsidian's `theme: "system"`, so one block serves both modes.
 */
body {
  /* Minimal swatches (used directly by many of Minimal's own rules) */
  --bg1: {{colors.surface.default.hex}} !important;
  --bg2: {{colors.surface_container_low.default.hex}} !important;
  --bg3: {{colors.surface_container_high.default.hex}} !important;
  --ui1: {{colors.surface_container_high.default.hex}} !important;
  --ui2: {{colors.surface_container_highest.default.hex}} !important;
  --ui3: {{colors.outline_variant.default.hex}} !important;
  --tx1: {{colors.on_surface.default.hex}} !important;
  --tx2: {{colors.on_surface_variant.default.hex}} !important;
  --tx3: {{colors.outline.default.hex}} !important;
  --ax1: {{colors.primary.default.hex}} !important;
  --ax2: {{colors.primary.default.hex}} !important;
  --ax3: {{colors.primary.default.hex}} !important;

  /* Obsidian core roles (surfaces Minimal drives through core vars) */
  --background-primary: {{colors.surface.default.hex}} !important;
  --background-primary-alt: {{colors.surface_container.default.hex}} !important;
  --background-secondary: {{colors.surface_container_low.default.hex}} !important;
  --background-secondary-alt: {{colors.surface_container.default.hex}} !important;
  --background-modifier-border: {{colors.surface_container_high.default.hex}} !important;
  --background-modifier-border-hover: {{colors.surface_container_highest.default.hex}} !important;
  --background-modifier-border-focus: {{colors.outline_variant.default.hex}} !important;
  --background-modifier-hover: {{colors.surface_container_highest.default.hex}} !important;
  --divider-color: {{colors.surface_container_high.default.hex}} !important;
  --text-normal: {{colors.on_surface.default.hex}} !important;
  --text-muted: {{colors.on_surface_variant.default.hex}} !important;
  --text-faint: {{colors.outline.default.hex}} !important;
  --text-accent: {{colors.primary.default.hex}} !important;
  --text-accent-hover: {{colors.tertiary.default.hex}} !important;
  --text-on-accent: {{colors.on_primary.default.hex}} !important;
  --interactive-accent: {{colors.primary.default.hex}} !important;
  --interactive-accent-hover: {{colors.tertiary.default.hex}} !important;
  --interactive-normal: {{colors.surface_container.default.hex}} !important;
  --interactive-hover: {{colors.surface_container_high.default.hex}} !important;
}
