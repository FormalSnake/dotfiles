/**
 * @name Noctalia (Midnight)
 * @description Wallpaper-derived dynamic Discord theme. Generated by Noctalia.
 * @author noctalia + refact0r/midnight-discord
 *
 * Written to ~/.config/equibop/themes/noctalia.theme.css. Equicord watches the
 * themes folder and hot-reloads on write — no reload hook needed. Enable once in
 * Equibop -> Settings -> Themes (adds it to settings/settings.json enabledThemes).
 * `.default` tokens track the active light/dark mode. NOTE: the midnight base is
 * dark-oriented; light mode may read oddly (acceptable per design).
 */
@import url('https://refact0r.github.io/midnight-discord/build/midnight.css');

:root {
  --accent-1: {{colors.tertiary.default.hex}};
  --accent-2: {{colors.primary.default.hex}};
  --accent-3: {{colors.primary.default.hex}};
  --accent-4: {{colors.primary.default.hex}};
  --accent-5: {{colors.primary_container.default.hex}};
  --mention: {{colors.primary.default.hex}};
  --online-indicator: {{colors.inverse_primary.default.hex}};
  --dnd-indicator: {{colors.error.default.hex}};

  --text-0: {{colors.background.default.hex}};
  --text-1: {{colors.on_surface.default.hex}};
  --text-2: {{colors.on_surface.default.hex}};
  --text-3: {{colors.on_surface_variant.default.hex}};
  --text-4: {{colors.on_surface_variant.default.hex}};
  --text-5: {{colors.outline.default.hex}};

  --bg-1: {{colors.surface_container_high.default.hex}};
  --bg-2: {{colors.surface_container.default.hex}};
  --bg-3: {{colors.surface_container_low.default.hex}};
  --bg-4: {{colors.surface.default.hex}};
  --hover: {{colors.surface_bright.default.hex}};
  --active: {{colors.surface_container_highest.default.hex}};
}
