-- Generated by Noctalia on every palette change (wallpaper pick / light-dark flip).
-- This file is dofile'd by hyprland.lua on each config eval (mixins/hyprland.nix), so
-- the wallpaper-derived border colours PERSIST across `hyprctl reload` and the startup
-- race instead of reverting to the static Catppuccin fallback. Noctalia ALSO pushes
-- these same values live (instant, no flicker) via the `hyprctl eval` post_hook in
-- mixins/noctalia.nix — this file is the persistent counterpart of that push. It must
-- stay valid Lua: it runs in hyprland.lua's global env, where `hl` is in scope.
-- primary = active border; secondary = active group; error = locked; surface = inactive.
hl.config({
  general = {
    col = {
      active_border   = "rgb({{ colors.primary.default.hex_stripped }})",
      inactive_border = "rgb({{ colors.surface.default.hex_stripped }})",
    },
  },
  group = {
    col = {
      border_active          = "rgb({{ colors.secondary.default.hex_stripped }})",
      border_inactive        = "rgb({{ colors.surface.default.hex_stripped }})",
      border_locked_active   = "rgb({{ colors.error.default.hex_stripped }})",
      border_locked_inactive = "rgb({{ colors.surface.default.hex_stripped }})",
    },
    groupbar = {
      col = {
        active          = "rgb({{ colors.secondary.default.hex_stripped }})",
        inactive        = "rgb({{ colors.surface.default.hex_stripped }})",
        locked_active   = "rgb({{ colors.error.default.hex_stripped }})",
        locked_inactive = "rgb({{ colors.surface.default.hex_stripped }})",
      },
    },
  },
})
