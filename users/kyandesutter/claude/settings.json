          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude session_end"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/kyandesutter/.claude/hooks/herdr-agent-state.sh' release",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
