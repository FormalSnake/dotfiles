    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude stop"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/kyandesutter/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10
          }
        ]
      }
