# Generated by matugen (DMS) from the active wallpaper palette. Do not edit.
# Written to ~/.config/yazi/flavors/dank.yazi/flavor.toml; programs.yazi.theme
# in programs.nix points ~/.config/yazi/theme.toml's [flavor] dark/light at
# "dank", so this one file covers both modes (re-rendered on every DMS flip).
# `.default` tokens track the active light/dark mode. Schema mirrors a stock
# yazi-rs/flavors flavor.toml; tertiary/secondary/error stand in for the
# success/warn/danger accents most flavors hand-pick.

[mgr]
cwd = { fg = "{{colors.primary.default.hex}}" }

find_keyword  = { fg = "{{colors.tertiary.default.hex}}", bold = true, italic = true, underline = true }
find_position = { fg = "{{colors.secondary.default.hex}}", bg = "reset", bold = true, italic = true }

marker_copied   = { fg = "{{colors.tertiary.default.hex}}", bg = "{{colors.tertiary.default.hex}}" }
marker_cut      = { fg = "{{colors.error.default.hex}}", bg = "{{colors.error.default.hex}}" }
marker_marked   = { fg = "{{colors.primary.default.hex}}", bg = "{{colors.primary.default.hex}}" }
marker_selected = { fg = "{{colors.secondary.default.hex}}", bg = "{{colors.secondary.default.hex}}" }

count_copied   = { fg = "{{colors.surface.default.hex}}", bg = "{{colors.tertiary.default.hex}}" }
count_cut      = { fg = "{{colors.surface.default.hex}}", bg = "{{colors.error.default.hex}}" }
count_selected = { fg = "{{colors.surface.default.hex}}", bg = "{{colors.secondary.default.hex}}" }

border_symbol = "│"
border_style  = { fg = "{{colors.outline.default.hex}}" }

[tabs]
active   = { fg = "{{colors.surface.default.hex}}", bg = "{{colors.primary.default.hex}}", bold = true }
inactive = { fg = "{{colors.primary.default.hex}}", bg = "{{colors.surface_container.default.hex}}" }

[mode]
normal_main = { fg = "{{colors.surface.default.hex}}", bg = "{{colors.primary.default.hex}}", bold = true }
normal_alt  = { fg = "{{colors.primary.default.hex}}", bg = "{{colors.surface_container.default.hex}}" }
select_main = { fg = "{{colors.surface.default.hex}}", bg = "{{colors.tertiary.default.hex}}", bold = true }
select_alt  = { fg = "{{colors.tertiary.default.hex}}", bg = "{{colors.surface_container.default.hex}}" }
unset_main  = { fg = "{{colors.surface.default.hex}}", bg = "{{colors.error.default.hex}}", bold = true }
unset_alt   = { fg = "{{colors.error.default.hex}}", bg = "{{colors.surface_container.default.hex}}" }

[status]
perm_sep   = { fg = "{{colors.outline.default.hex}}" }
perm_type  = { fg = "{{colors.primary.default.hex}}" }
perm_read  = { fg = "{{colors.secondary.default.hex}}" }
perm_write = { fg = "{{colors.error.default.hex}}" }
perm_exec  = { fg = "{{colors.tertiary.default.hex}}" }

progress_label  = { fg = "{{colors.on_surface.default.hex}}", bold = true }
progress_normal = { fg = "{{colors.tertiary.default.hex}}", bg = "{{colors.surface_container_high.default.hex}}" }
progress_error  = { fg = "{{colors.secondary.default.hex}}", bg = "{{colors.error.default.hex}}" }

[pick]
border   = { fg = "{{colors.primary.default.hex}}" }
active   = { fg = "{{colors.tertiary.default.hex}}", bold = true }
inactive = {}

[input]
border   = { fg = "{{colors.primary.default.hex}}" }
title    = {}
value    = {}
selected = { reversed = true }

[cmp]
border = { fg = "{{colors.primary.default.hex}}" }

[tasks]
border  = { fg = "{{colors.primary.default.hex}}" }
title   = {}
hovered = { fg = "{{colors.tertiary.default.hex}}", bold = true }

[which]
mask            = { bg = "{{colors.surface_container.default.hex}}" }
cand            = { fg = "{{colors.tertiary.default.hex}}" }
rest            = { fg = "{{colors.outline.default.hex}}" }
desc            = { fg = "{{colors.secondary.default.hex}}" }
separator       = "  "
separator_style = { fg = "{{colors.outline_variant.default.hex}}" }

[help]
on      = { fg = "{{colors.tertiary.default.hex}}" }
run     = { fg = "{{colors.secondary.default.hex}}" }
hovered = { reversed = true, bold = true }
footer  = { fg = "{{colors.surface_container.default.hex}}", bg = "{{colors.on_surface.default.hex}}" }

[spot]
border   = { fg = "{{colors.primary.default.hex}}" }
title    = { fg = "{{colors.primary.default.hex}}" }
tbl_col  = { fg = "{{colors.tertiary.default.hex}}" }
tbl_cell = { fg = "{{colors.secondary.default.hex}}", bg = "{{colors.surface_container_high.default.hex}}" }

[notify]
title_info  = { fg = "{{colors.tertiary.default.hex}}" }
title_warn  = { fg = "{{colors.secondary.default.hex}}" }
title_error = { fg = "{{colors.error.default.hex}}" }
