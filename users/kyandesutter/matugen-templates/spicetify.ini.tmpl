; Generated by matugen (DMS) from the active wallpaper palette. Do not edit.
; Written to ~/.config/spicetify/Themes/text/color.ini; selected by
; `current_theme = text` + `color_scheme = Matugen` in config-xpui.ini (both
; enforced on activation by mixins/spicetify.nix, which also vendors the text
; theme's user.css). The `spicetify` user template's post_hook re-applies it
; (see mixins/dms.nix). hex_stripped = bare hex (no leading #), which spicetify
; color.ini requires. `.default` tokens track the active light/dark mode. Slot
; names match the text theme's color.ini schema; the mapping mirrors the
; theme's stock schemes (accent-inactive = background, header a step above
; highlight).
[Matugen]
accent             = {{ colors.primary.default.hex_stripped }}
accent-active      = {{ colors.primary.default.hex_stripped }}
accent-inactive    = {{ colors.surface.default.hex_stripped }}
banner             = {{ colors.primary.default.hex_stripped }}
border-active      = {{ colors.primary.default.hex_stripped }}
border-inactive    = {{ colors.outline_variant.default.hex_stripped }}
header             = {{ colors.surface_container_highest.default.hex_stripped }}
highlight          = {{ colors.surface_container_high.default.hex_stripped }}
main               = {{ colors.surface.default.hex_stripped }}
notification       = {{ colors.primary.default.hex_stripped }}
notification-error = {{ colors.error.default.hex_stripped }}
subtext            = {{ colors.on_surface_variant.default.hex_stripped }}
text               = {{ colors.on_surface.default.hex_stripped }}
